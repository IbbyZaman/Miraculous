<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Miraculous Hub - Home</title>
    <style>
        /* Global Styles & Dark Theme */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #0b0c10;
            color: #c5c6c7;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            scroll-behavior: smooth;
        }

        /* Navigation Bar */
        header {
            background-color: #1f2833;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid #e50914; 
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        header h1 {
            color: #ffffff;
            font-size: 24px;
            letter-spacing: 1px;
        }

        header h1 span {
            color: #e50914;
        }

        nav a {
            color: #c5c6c7;
            text-decoration: none;
            margin-left: 20px;
            font-weight: 600;
            transition: color 0.3s ease;
        }

        nav a:hover, nav a.active {
            color: #e50914;
        }

        /* Layout Container */
        .container {
            max-width: 1200px;
            margin: 40px auto;
            padding: 0 20px;
            width: 100%;
            flex: 1;
        }

        /* Hero Banner Section */
        .hero-banner {
            background: linear-gradient(135deg, #1f2833, #0b0c10);
            border: 1px solid rgba(229, 9, 20, 0.3);
            border-radius: 12px;
            padding: 50px 30px;
            text-align: center;
            margin-bottom: 40px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.7);
        }

        .hero-banner h2 {
            color: #fff;
            font-size: 36px;
            margin-bottom: 15px;
        }

        .hero-banner h2 span {
            color: #e50914;
        }

        .hero-banner p {
            color: #8f9aa6;
            font-size: 16px;
            max-width: 700px;
            margin: 0 auto 30px auto;
            line-height: 1.6;
        }

        /* Section Title */
        .section-title {
            color: #e50914;
            margin: 30px 0 20px 0;
            font-size: 22px;
            border-left: 4px solid #e50914;
            padding-left: 10px;
        }

        /* Directory Hub Grid Cards */
        .hub-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 25px;
        }

        .hub-card {
            background-color: #1f2833;
            border-radius: 8px;
            overflow: hidden;
            text-decoration: none;
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
        }

        .hub-card:hover {
            transform: translateY(-5px);
            border-color: #e50914;
            box-shadow: 0 8px 25px rgba(229, 9, 20, 0.3);
        }

        .hub-card-banner {
            height: 140px;
            background: linear-gradient(45deg, #151b22, #283342);
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .hub-card-banner span {
            font-size: 28px;
            font-weight: bold;
            color: #fff;
            letter-spacing: 2px;
        }

        .hub-card-banner::after {
            content: 'EXPLORE →';
            position: absolute;
            bottom: 10px;
            right: 15px;
            font-size: 11px;
            color: #e50914;
            font-weight: bold;
            letter-spacing: 1px;
            opacity: 0;
            transition: opacity 0.3s ease;
        }

        .hub-card:hover .hub-card-banner::after {
            opacity: 1;
        }

        .hub-card-content {
            padding: 20px;
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .hub-card-content h3 {
            color: #fff;
            font-size: 20px;
            margin-bottom: 8px;
        }

        .hub-card-content p {
            color: #8f9aa6;
            font-size: 14px;
            line-height: 1.5;
        }

        footer {
            background-color: #0b0c10;
            text-align: center;
            padding: 20px;
            font-size: 14px;
            color: #666;
            border-top: 1px solid #1f2833;
            margin-top: 40px;
        }

        /* Mobile Responsive Overrides */
        @media (max-width: 768px) {
            header {
                padding: 15px;
                flex-direction: column;
                gap: 10px;
                text-align: center;
            }

            nav a {
                margin: 0 8px;
                font-size: 13px;
            }

            .container {
                margin: 20px auto;
                padding: 0 15px;
            }

            .hero-banner {
                padding: 30px 15px;
            }

            .hero-banner h2 {
                font-size: 26px;
            }

            .hero-banner p {
                font-size: 14px;
            }
        }
    </style>
</head>
<body>

    <!-- Header / Navbar Layout Navigation -->
    <header>
        <h1>MIRACULOUS<span>HUB</span></h1>
        <nav>
            <a href="index.html" class="active">Home</a>
            <a href="season-5.html">Season 5</a>
            <a href="season-6.html">Season 6</a>
            <a href="specials.html">Special Episodes</a>
        </nav>
    </header>

    <div class="container">
        <!-- Hero Section -->
        <div class="hero-banner">
            <h2>Welcome to Miraculous <span>Hub</span></h2>
            <p>Your ultimate dark-themed streaming gateway for all the latest episodes, seasons, and specials.</p>
        </div>

        <h3 class="section-title">Select a Directory</h3>
        
        <!-- Hub Grid Links -->
        <div class="hub-grid">
            <a href="season-5.html" class="hub-card">
                <div class="hub-card-banner">
                    <span>SEASON 5</span>
                </div>
                <div class="hub-card-content">
                    <div>
                        <h3>Season 5 Streaming</h3>
                        <p>Access full episodes from Evolution through Migration with optimized streaming layouts.</p>
                    </div>
                </div>
            </a>

            <a href="season-6.html" class="hub-card">
                <div class="hub-card-banner">
                    <span>SEASON 6</span>
                </div>
                <div class="hub-card-content">
                    <div>
                        <h3>Season 6 Directory</h3>
                        <p>Stream the latest Season 6 releases from Climatiqueen to Queen Of The Dreadzone.</p>
                    </div>
                </div>
            </a>

            <a href="specials.html" class="hub-card">
                <div class="hub-card-banner">
                    <span>SPECIALS</span>
                </div>
                <div class="hub-card-content">
                    <div>
                        <h3>Special Episodes</h3>
                        <p>Explore movie features, world specials, and additional cinematic content.</p>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <footer>
        &copy; 2026 Miraculous Hub. For personal configurations.
    </footer>

</body>
</html>
